---
import Base from "../layouts/Base.astro";
---

<Base title="About">
  <section class="about">
    <header class="about-header">
      <p class="about-label body-sm">Selected About</p>
      <h1 class="heading-lg">ABOUT ME</h1>
    </header>

    <div class="about-inner">
      <div class="about-bio">
        <p>
          Hi, my name is Francesca Romana Antonucci, I'm a graphic designer with
          a passion for cinema and design, with a strong focus on balancing
          aesthetics and communication. For me, every project is an opportunity
          to transform ideas into effective visual solutions that convey
          identity in a clear and distinctive way.
        </p>
      </div>

      <div class="about-portrait">
        <img
          src="/images/about/portrait.webp"
          alt="Francesca Romana Antonucci"
        />
      </div>
    </div>
  </section>
</Base>

<style>
  .about {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding: 120px 32px 120px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .about-header {
    margin-bottom: 48px;
  }

  .about-label {
    color: var(--color-muted);
    margin-bottom: 10px;
  }

  .about-inner {
    flex: 1;
    display: grid;
    grid-template-columns: 55fr 35fr;
    gap: 80px;
    align-items: center;
    align-content: start;
  }

  .about-bio {
    border: 2px solid var(--color-text);
    border-radius: 20px;
    padding: 16px 18px;
  }

  .about-bio p {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.5vw, 18px);
    font-weight: 700;
    line-height: 1.65;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .about-portrait {
    aspect-ratio: 329 / 369;
    overflow: hidden;
    background: #e8e6df;
    border: 2px solid var(--color-text);
    border-radius: 20px;
  }

  .about-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 768px) {
    .about {
      padding: 104px 24px 100px;
    }

    .about-inner {
      grid-template-columns: 1fr;
      gap: 40px;
      justify-items: center;
    }

    .about-bio {
      width: 100%;
    }

    .about-portrait {
      max-width: 280px;
    }
  }

  @media (max-width: 480px) {
    .about {
      padding: 96px 16px 128px;
    }

    .about-bio p {
      font-size: 13px;
    }
  }
</style>
