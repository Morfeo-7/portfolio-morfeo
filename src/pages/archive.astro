---

<Base title="Archive" dark={true}>
  <section class="archive">
    <header class="archive-header">
      <p class="archive-label body-sm">Archive</p>
      <h1 class="archive-headline heading-lg">
        PREVIOUS WORK<br />& EXPERIMENTS.
      </h1>
      <p class="archive-note body-md">
        A collection of previous projects, design experiments, and research.
      </p>
    </header>
    <div class="archive-grid">
      {
        media.map((item, i) =>
          item.type === "video" ? (
            <div class="archive-item">
              <video src={item.src} autoplay loop muted playsinline preload="none" />
            </div>
          ) : (
            <div class="archive-item">
              <img src={item.src} alt={`Archive ${i + 1}`} loading="lazy" />
            </div>
          ),
        )
      }
    </div>
  </section>
</Base>

<style>
  .archive {
    padding: 120px 32px 120px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .archive-header {
    margin-bottom: 48px;
  }

  .archive-label {
    color: var(--color-muted);
    margin-bottom: 10px;
  }

  .archive-headline {
    margin-bottom: 10px;
  }

  .archive-note {
    color: var(--color-muted);
    max-width: 480px;
    line-height: 1.7;
  }

  .archive-grid {
    columns: 3;
    gap: 8px;
  }

  .archive-item {
    break-inside: avoid;
    margin-bottom: 8px;
  }

  .archive-item img,
  .archive-item video {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 12px;
  }

  @media (max-width: 1024px) {
    .archive-grid {
      columns: 2;
    }
  }

  @media (max-width: 768px) {
    .archive {
      padding: 104px 24px 100px;
    }

    .archive-grid {
      columns: 2;
    }
  }

  @media (max-width: 480px) {
    .archive {
      padding: 100px 16px 128px;
    }

    .archive-grid {
      columns: 1;
    }
  }
</style>
