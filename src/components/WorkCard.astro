---
interface Props {
  number: string;
  title: string;
  tags?: string[];
  href: string;
  cover?: string;
}

const { number, title, tags = [], href, cover } = Astro.props;
---

<a href={href} class="work-card">
  <div class="work-card-cover">
    {cover ? (
      cover.endsWith('.mp4') ? (
        <video src={cover} autoplay loop muted playsinline />
      ) : (
        <img src={cover} alt={title} loading="lazy" width="800" height="450" />
      )
    ) : (
      <div class="work-card-placeholder" />
    )}
  </div>
  <div class="work-card-meta">
    <span class="work-card-number">{number}</span>
    <h2 class="work-card-title">{title}</h2>
    {
      tags.length > 0 && (
        <ul class="work-card-tags">
          {tags.map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
      )
    }
  </div>
</a>

<style>
  .work-card {
    display: block;
    padding: 16px 18px;
    border: 2px solid #f0eeea;
    border-radius: 20px;
    color: var(--color-text);
  }

  .work-card-cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #000;
    margin-bottom: 14px;
  }

  .work-card-cover img,
  .work-card-cover video {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 600ms var(--ease-page);
  }

  .work-card-placeholder {
    width: 100%;
    height: 100%;
    background: #f0eeea;
  }

  .work-card:hover .work-card-cover img,
  .work-card:hover .work-card-cover video {
    transform: scale(1.03);
  }

  .work-card-meta {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .work-card-number {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .work-card-title {
    font-family: var(--font-display);
    font-size: clamp(18px, 2vw, 24px);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--color-text);
    background-image: linear-gradient(
      to right,
      var(--color-text),
      var(--color-text)
    );
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0% 1px;
    padding-bottom: 1px;
    transition: background-size 0.3s var(--ease-page);
    display: inline;
  }

  .work-card:hover .work-card-title {
    background-size: 100% 1px;
  }

  .work-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 2px;
  }

  .work-card-tags li {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
</style>
