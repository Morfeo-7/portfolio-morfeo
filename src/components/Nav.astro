---
const pathname = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
};

const links = [
  { href: "/work/",    label: "WORK" },
  { href: "/about/",   label: "ABOUT" },
  { href: "/archive/", label: "ARCHIVE" },
  { href: "/contact/", label: "CONTACT" },
];
---

<header class="nav">
  <nav class="nav-inner">
    <a href="/" class="nav-logo" transition:name="nav-logo">MORFEO</a>

    {links.map(({ href, label }) => (
      <a href={href} class:list={["nav-link", { active: isActive(href) }]}>
        {label}
      </a>
    ))}

    <button
      class="hamburger"
      id="hamburger"
      aria-label="Apri menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </nav>
</header>

<div class="mobile-menu" id="mobile-menu" role="dialog" aria-label="Navigazione">
  {links.map(({ href, label }) => (
    <a href={href} class:list={["mobile-link", { active: isActive(href) }]}>
      {label}
    </a>
  ))}
</div>

<script>
  function initNav() {
    const hamburger = document.getElementById("hamburger") as HTMLButtonElement;
    const menu = document.getElementById("mobile-menu") as HTMLDivElement;
    if (!hamburger || !menu) return;

    // Clone and replace to remove any old event listeners (prevents duplicates)
    const freshHamburger = hamburger.cloneNode(true) as HTMLButtonElement;
    hamburger.replaceWith(freshHamburger);

    function close() {
      menu.classList.remove("open");
      freshHamburger.classList.remove("open");
      freshHamburger.setAttribute("aria-expanded", "false");
    }

    freshHamburger.addEventListener("click", () => {
      const opening = !menu.classList.contains("open");
      menu.classList.toggle("open");
      freshHamburger.classList.toggle("open");
      freshHamburger.setAttribute("aria-expanded", String(opening));
    });

    menu.querySelectorAll("a").forEach((a) => a.addEventListener("click", close));
    document.addEventListener("keydown", (e) => e.key === "Escape" && close());
  }

  // astro:page-load fires on BOTH initial load and after client-side navigation
  document.addEventListener("astro:page-load", initNav);
</script>

<style>
  /* ── Nav pill ─────────────────────────────────────── */
  .nav {
    position: fixed;
    top: 40px;
    left: 30px;
    right: 30px;
    z-index: 100;
    height: 56px;
    background: var(--color-bg);
    border: 2px solid var(--color-text);
    border-radius: 20px;
    display: flex;
    align-items: center;
  }

  .nav-inner {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  /* ── Desktop links ────────────────────────────────── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--color-text);
    opacity: 0.75;
    padding-bottom: 1px;
    background-image: linear-gradient(to right, var(--color-text), var(--color-text));
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0% 1px;
    transition:
      background-size 0.25s var(--ease-page),
      opacity 0.2s ease;
  }

  .nav-link:hover {
    opacity: 1;
    background-size: 100% 1px;
  }

  .nav-link.active {
    opacity: 1;
    background-size: 100% 1px;
  }

  /* ── Hamburger (hidden on desktop) ───────────────── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    padding: 4px;
    cursor: pointer;
    width: 32px;
    height: 32px;
    flex-shrink: 0;
  }

  .bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transform-origin: center;
    transition:
      transform 0.25s var(--ease-page),
      opacity 0.2s ease;
  }

  .hamburger.open .bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open .bar:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open .bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── Mobile dropdown (hidden on desktop) ─────────── */
  .mobile-menu {
    display: none;
  }

  /* ── Mobile overrides ─────────────────────────────── */
  @media (max-width: 768px) {
    .nav {
      top: 26px;
      left: 8px;
      right: 8px;
      height: 52px;
    }

    .nav-inner {
      padding: 0 16px;
    }

    .nav-logo {
      font-size: 14px;
    }

    .nav-link {
      display: none;
    }

    .hamburger {
      display: flex;
    }

    /* Dropdown pill */
    .mobile-menu {
      display: block;
      position: fixed;
      top: 86px; /* 26 nav-top + 52 height + 8 gap */
      left: 8px;
      right: 8px;
      z-index: 99;
      background: var(--color-bg);
      border: 2px solid var(--color-text);
      border-radius: 20px;
      padding: 8px;
      opacity: 0;
      transform: translateY(-6px);
      pointer-events: none;
      transition:
        opacity 0.2s var(--ease-page),
        transform 0.2s var(--ease-page);
    }

    .mobile-menu.open {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    .mobile-link {
      display: block;
      padding: 14px 16px;
      font-family: var(--font-body);
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-text);
      border-radius: 12px;
      transition:
        background-color 0.18s var(--ease-page),
        color 0.18s var(--ease-page);
    }

    .mobile-link:hover {
      background-color: var(--color-text);
      color: var(--color-bg);
    }

    .mobile-link.active {
      background-color: var(--color-text);
      color: var(--color-bg);
    }
  }
</style>
